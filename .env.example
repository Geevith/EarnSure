# App
APP_NAME="EarnSure Backend"
DEBUG=true
ENVIRONMENT=development

# Security
SECRET_KEY=your-key
INTERNAL_API_KEY=your-key

# Database
DATABASE_URL=postgresql+asyncpg://db:pass@localhost:5432/earnsure_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Weather (Visual Crossing)
WEATHER_API_KEY=your-key

# Traffic (TomTom)
TOMTOM_API_KEY=your-key

# News / NLP
NEWS_API_KEY=your-key
HF_API_TOKEN=your-token

# Razorpay (use test keys in sandbox)
RAZORPAY_KEY_ID=your-keyxxxx
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_ACCOUNT_NUMBER=your-acc

# Webhook secrets
WEBHOOK_SECRET_ZOMATO=secret-key
WEBHOOK_SECRET_SWIGGY=secret-key